theme = GitHub Dark
font-family = Monaspace Neon
font-size = 14

# ─── Window ───
window-padding-x = 8
window-padding-y = 4
window-decoration = true
macos-titlebar-style = tabs

# ─── Cursor ───
cursor-style = block
cursor-style-blink = false

# ��── Mouse ───
mouse-hide-while-typing = true
copy-on-select = clipboard

# ─── Shell integration ───
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# ─── Clipboard ───
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = true

# ─── Keybindings ───
# Split panes
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+w=close_surface

# Navigate splits
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+alt+down=goto_split:bottom

# Resize splits
keybind = super+ctrl+left=resize_split:left,20
keybind = super+ctrl+right=resize_split:right,20
keybind = super+ctrl+up=resize_split:up,20
keybind = super+ctrl+down=resize_split:down,20

# Equalize splits
keybind = super+shift+equal=equalize_splits

# Font size
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+0=reset_font_size
